{
  "name": "@q-cms/cli",
  "version": "0.1.0",
  "description": "Q-CMS CLI",
  "type": "module",
  "bin": {
    "q-cms": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --minify",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@q-cms/core": "workspace:*",
    "@q-cms/sdk": "workspace:*",
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "inquirer": "12.1.0",
    "ora": "8.1.1"
  },
  "devDependencies": {
    "@q-cms/config": "workspace:*",
    "@types/node": "22.10.2",
    "@vitest/coverage-v8": "2.1.8",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
