{
  "name": "@q-cms/collab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "start": "bun run dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@hocuspocus/extension-database": "2.15.2",
    "@hocuspocus/extension-logger": "2.15.2",
    "@hocuspocus/extension-redis": "2.15.2",
    "@hocuspocus/server": "2.15.2",
    "@q-cms/auth": "workspace:*",
    "@q-cms/core": "workspace:*",
    "@q-cms/db": "workspace:*",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@q-cms/config": "workspace:*",
    "@types/node": "22.10.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
