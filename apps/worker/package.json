{
  "name": "@q-cms/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ."
  },
  "dependencies": {
    "@q-cms/core": "workspace:*",
    "@q-cms/db": "workspace:*",
    "@q-cms/media": "workspace:*",
    "@q-cms/search": "workspace:*",
    "bullmq": "5.34.0",
    "ioredis": "5.4.1",
    "nodemailer": "6.9.16",
    "drizzle-orm": "0.33.0",
    "pino": "9.5.0",
    "prom-client": "15.1.3",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@q-cms/config": "workspace:*",
    "@types/node": "22.10.2",
    "@types/nodemailer": "6.4.17",
    "@vitest/coverage-v8": "2.1.8",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
