# ============================================
# Q-CMS Environment Configuration
# ============================================
# Copy to .env and fill in real values

# --- Core ---
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
API_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Web app origin — used by the admin's PageBuilder preview iframe
# (must be reachable from the browser; CORS is permissive in dev).
NEXT_PUBLIC_QCMS_WEB_URL=http://localhost:3002
COLLAB_PORT=1234

# --- Database (PostgreSQL 17) ---
DATABASE_URL=postgres://qcms:qcms@localhost:5432/qcms
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Cache & Queue (Redis 7) ---
REDIS_URL=redis://localhost:6379
REDIS_DB_CACHE=0
REDIS_DB_QUEUE=1
REDIS_DB_SESSIONS=2

# --- Search (Meilisearch) ---
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterKey-change-me-in-prod

# --- Object Storage (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=qcms-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Auth ---
JWT_SECRET=change-me-with-openssl-rand-base64-32-chars-min
JWT_ACCESS_TTL=900          # 15 min
JWT_REFRESH_TTL=2592000     # 30 days
SESSION_COOKIE_NAME=qcms_session

# --- Security ---
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
CSP_NONCE=enabled
RATE_LIMIT_PER_MIN=600
LOGIN_RATE_LIMIT=5

# --- Webhooks ---
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=3

# --- Email (SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@q-cms.local

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=q-cms-api
SENTRY_DSN=
METRICS_ENABLED=true
LOG_FORMAT=json

# --- Features ---
DOCS_ENABLED=true
REGISTRATION_OPEN=false
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ru,de
